---

import Footer from '../components/Footer.astro';
import Menu from '../components/Menu.astro';
import Header from '../components/Menu.astro';
import '../styles/global.css';
---
<body>
    

<Menu />
<h1>Tilmeld dit event</h1>
<section class="form-wrap">
  <form method="POST" action="/api/tilmeld">
    <div class="field">
      <label for="firma">Firmanavn</label>
      <input type="text" id="firma" name="firma" required />
    </div>
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required />
    </div>
    <div class="field">
      <label for="tlf">Telefonnummer</label>
      <input type="tel" id="tlf" name="tlf" />
    </div>
    <div class="field">
      <label for="lokation">Lokation</label>
      <input type="text" id="lokation" name="lokation" />
    </div>
    <div class="field">
      <label for="om">Kort om dig/ jer</label>
      <textarea id="om" name="om"></textarea>
    </div>
    <div class="choice">
  <label>
    <input type="radio" name="eventType" value="har-event" />
    Jeg har et event
  </label>

  <label>
    <input type="radio" name="eventType" value="deltage-event" />
    Jeg vil deltage til et event
  </label>
</div>
    <div class="btn-wrap">
      <button class="button" type="submit">Tilmeld her</button>
    </div>
  </form>
</section>



</body>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&display=swap');

  .form-wrap {
    background: #E8E0D5;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    max-width: 400px;
    margin: 1.5rem auto;
    font-family: 'DM Sans', sans-serif;
  }

  .field {
    margin-bottom: 1.5rem;
  }

  .field label {
    display: block;
    font-size: 0.95rem;
    color: #2a2a2a;
    margin-bottom: 0.5rem;
  }

  .field input,
  .field textarea {
    width: 100%;
    box-sizing: border-box;
    background: #E2E8EF;
    border: none;
    border-radius: 8px;
    padding: 0.85rem 1rem;
    font-family: 'inter', sans-serif;
    font-size: 1rem;
    color: #1a1a1a;
    outline: 1px solid rgb(189, 189, 189);
    resize: none;
  }

  .field textarea {
    height: 70px;
  }

  .field input:focus,
  .field textarea:focus {
    background: #d8dfe8;
  }

  .btn-wrap {
    text-align: center;
    margin-top: 2rem;
}
.button {
   display: block;
    width: 6rem;
    padding: 0.5rem;
    border-radius: 0.2rem;
    margin-bottom: 0.5rem;
    background-color: #402A32;
    color: #fff;
    text-align: center;
  justify-self: center;
    text-decoration: none;
    
font-family: 'inter', sans-serif;
    font-weight: bold;}
    .button:hover {
      background-color: #5a3739;
    }

h1 {
  text-align: center;
margin-bottom: 1.5rem;
font-family: 'dela gothic one', sans-serif;
}