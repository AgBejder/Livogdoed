<section class="hero">
  <img class="hero-img" src="/Hero.webp" alt="Uge 44" />
  <div class="hero-text">
    <h1>UGE44</h1>
    <h2 class="h2-hero">En Samtale Om Døden</h2>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-text {
    position: absolute;
    bottom: 6rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    width: 100%;
  }


  p {
    font-size: 2rem;
    color: #333;
    margin-top: 0.5rem;
    letter-spacing: 1px;
  }

  .hero h1{
    font-family: 'Dela Gothic One', sans-serif;
    font-weight: normal;
      font-size: 2rem;
      font-weight: 900;
      color: #e8264a;
      margin: 0;
      letter-spacing: 2px;
    }

    .hero h2{
      font-family: 'Dela Gothic One', sans-serif;
    font-weight: normal;
    font-size: 1.5rem;
    }
  

  h2 {
    font-family: 'Inter', sans-serif;
    font-weight: normal;
    font-size: 0.5rem;
    color: #3a3a3a;
    margin: 0 0 
    1rem 0;
  }

  @media (max-width: 768px) {

    .hero-text {
    bottom: 2rem;
    }

    p {
      font-size: 0.9rem;
    }
  }

  /* desktop */
  @media (min-width: 1024px) {
    .hero h1{
      font-size: 6rem;
    }

    .hero h2{
        font-size: 3rem;
      }
  }
</style>
