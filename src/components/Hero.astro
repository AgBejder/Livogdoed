<section class="hero">
  <img class="hero-img" src="/Hero.webp" alt="Uge 44" />
  <div class="hero-text">
    <h1>UGE44</h1>
    <p>En Samtale Om Døden</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-text {
    position: absolute;
    bottom: 6rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    width: 100%;
  }

  h1 {
    font-size: 6rem;
    font-weight: 900;
    color: #e8264a;
    margin: 0;
    letter-spacing: 2px;
  }

  p {
    font-size: 2rem;
    color: #333;
    margin-top: 0.5rem;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {

    .hero-text {
    bottom: 2rem;
    }

    h1 {
      font-size: 2rem;

    }

    p {
      font-size: 0.9rem;
    }
  }
</style>
