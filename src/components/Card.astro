---
const{eventData}=Astro.props

---

<article>
  <img src={eventData.photo} alt={eventData.event_name}>
    <h2>{eventData.event_name}</h2>
     <p>{eventData.date}</p>
    <p>{eventData.place}</p>
    <p>{eventData.deskription}</p>
   
</article>

<style>
    img {
        max-width: 100%;
        max-height: 100%;
           display: block;
        object-fit: cover;
     aspect-ratio: 1/1;
    }
    article {

    
        margin: 1rem;
        background-color: #E4DDD3;
  overflow: hidden;
     
    }
    h2 {
        font-size: 1rem;
        margin-bottom: 0.5rem;
       
        justify-items: center;

    }
    p, h2{
        margin: 1rem;
        text-align: center;
    }
 
</style>